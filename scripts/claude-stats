#!/usr/bin/env python3
"""
claude-stats - Query Claude usage statistics

Usage:
    claude-stats              # Show current status
    claude-stats today        # Today's usage
    claude-stats week         # This week's usage
    claude-stats reset        # Time until next reset
    claude-stats json         # Output as JSON
    claude-stats --watch      # Live updates (5s interval)
    claude-stats --watch 2    # Live updates (2s interval)
    claude-stats log chat     # Log 1 chat event manually
    claude-stats log code 2   # Log 2 code events manually
    claude-stats log cowork   # Log 1 cowork event manually

Author: Vector
Created: 2026-03-07
Updated: 2026-03-07 (added manual logging)
"""

import os
import sys
import json
import time
import argparse
from pathlib import Path
from datetime import datetime, timedelta


def detect_claude_home():
    """Detect CLAUDE_HOME directory"""
    if env_home := os.getenv('CLAUDE_HOME'):
        return Path(env_home)
    
    if sys.platform == 'win32':
        for drive in ['D:', 'C:']:
            candidate = Path(f"{drive}/Claude")
            if candidate.exists():
                return candidate
    
    unix_home = Path.home() / "Claude"
    if unix_home.exists():
        return unix_home
    
    laptop_home = Path.home() / "continuity-bridge_tallest-anchor"
    if laptop_home.exists():
        return laptop_home
    
    return None


def load_state(state_file: Path):
    """Load tracker state"""
    if not state_file.exists():
        return None
    
    with open(state_file) as f:
        return json.load(f)


def save_state(state_file: Path, state):
    """Save tracker state"""
    state_file.parent.mkdir(parents=True, exist_ok=True)
    
    # Atomic write
    temp_file = state_file.with_suffix('.tmp')
    with open(temp_file, 'w') as f:
        json.dump(state, f, indent=2)
    temp_file.replace(state_file)


def log_manual_event(state_file: Path, product: str, count: int = 1):
    """Manually log usage event"""
    # Weight mapping
    weights = {
        'chat': 1.0,
        'code': 5.0,
        'cowork': 10.0
    }
    
    if product not in weights:
        print(f"ERROR: Invalid product '{product}'. Use: chat, code, or cowork", file=sys.stderr)
        return False
    
    # Load or create state
    state = load_state(state_file)
    if not state:
        state = {
            'plan': 'pro',
            'window_hours': 5,
            'events': []
        }
    
    # Add events
    now = datetime.now()
    weight = weights[product]
    
    for _ in range(count):
        event = {
            'timestamp': now.isoformat(),
            'product': product,
            'weight': weight,
            'source': 'manual'
        }
        state['events'].append(event)
    
    # Save state
    save_state(state_file, state)
    
    total_weight = count * weight
    print(f"✓ Logged {count}x {product} event(s) ({total_weight:.1f} units)")
    return True


def calculate_status(state):
    """Calculate current status from state"""
    if not state or 'events' not in state:
        return None
    
    # Plan limits
    limits = {
        'pro': 45,
        'max_5x': 225,
        'max_20x': 900
    }
    
    plan = state.get('plan', 'pro')
    window_hours = state.get('window_hours', 5)
    limit = limits.get(plan, 45)
    
    # Filter events in current window
    cutoff = datetime.now() - timedelta(hours=window_hours)
    events = []
    
    for event in state['events']:
        event_time = datetime.fromisoformat(event['timestamp'])
        if event_time >= cutoff:
            events.append(event)
    
    # Calculate usage
    total_weight = sum(e['weight'] for e in events)
    
    # Breakdown by product
    by_product = {}
    for product in ['chat', 'code', 'cowork']:
        product_events = [e for e in events if e['product'] == product]
        by_product[product] = {
            'count': len(product_events),
            'weight': sum(e['weight'] for e in product_events)
        }
    
    # Next reset
    if events:
        oldest = min(datetime.fromisoformat(e['timestamp']) for e in events)
        next_reset = oldest + timedelta(hours=window_hours)
        time_to_reset = next_reset - datetime.now()
    else:
        next_reset = None
        time_to_reset = timedelta(0)
    
    remaining = max(0, limit - total_weight)
    percent = (total_weight / limit) * 100 if limit > 0 else 0
    
    return {
        'plan': plan,
        'window_hours': window_hours,
        'limit': limit,
        'used': total_weight,
        'remaining': remaining,
        'percent': percent,
        'by_product': by_product,
        'next_reset': next_reset.isoformat() if next_reset else None,
        'time_to_reset': {
            'hours': int(time_to_reset.total_seconds() // 3600),
            'minutes': int((time_to_reset.total_seconds() % 3600) // 60)
        },
        'event_count': len(events)
    }


def format_bar(percent, width=20):
    """Create progress bar"""
    filled = int(width * percent / 100)
    empty = width - filled
    return '│' + '█' * filled + '░' * empty + '│'


def clear_screen():
    """Clear terminal screen"""
    os.system('clear' if os.name != 'nt' else 'cls')


def print_status(status, show_timestamp=False):
    """Print formatted status"""
    if not status:
        print("No usage data available")
        print("Daemon may not be running or no activity detected yet")
        return
    
    if show_timestamp:
        now = datetime.now().strftime('%I:%M:%S %p')
        print(f"Updated: {now}")
        print()
    
    print(f"Claude Usage Monitor")
    print(f"{'─' * 40}")
    print()
    print(f"Plan: {status['plan'].upper()}")
    print(f"Rolling Window ({status['window_hours']}hr): {status['used']:.1f}/{status['limit']} ({status['percent']:.0f}%)")
    print(format_bar(status['percent']))
    print()
    
    print("Breakdown:")
    for product in ['chat', 'code', 'cowork']:
        data = status['by_product'][product]
        if data['count'] > 0:
            print(f"  {product.capitalize():8} {data['count']:3} events  ({data['weight']:.1f} units)")
    
    print(f"{'─' * 40}")
    print(f"Total:              {status['event_count']:3} events  ({status['used']:.1f} units)")
    print()
    
    if status['next_reset']:
        reset = status['time_to_reset']
        print(f"Next reset: {reset['hours']}h {reset['minutes']}m")
    
    # Warnings
    if status['percent'] >= 95:
        print()
        print("⚠️  CRITICAL: Near usage limit!")
    elif status['percent'] >= 90:
        print()
        print("⚠️  WARNING: Usage high - consider waiting for reset")
    elif status['percent'] >= 80:
        print()
        print("ℹ️  Usage elevated - monitor carefully")
    
    if show_timestamp:
        print()
        print("Press Ctrl+C to exit")


def main():
    parser = argparse.ArgumentParser(description='Query Claude usage statistics')
    parser.add_argument('command', nargs='?', default='status',
                       help='Command to execute (status, reset, json, log)')
    parser.add_argument('product', nargs='?',
                       help='Product type for log command (chat, code, cowork)')
    parser.add_argument('count', nargs='?', type=int, default=1,
                       help='Number of events to log (default: 1)')
    parser.add_argument('--watch', '-w', nargs='?', const=5, type=int, metavar='INTERVAL',
                       help='Live updates mode (default: 5 seconds)')
    
    args = parser.parse_args()
    
    # Detect CLAUDE_HOME
    claude_home = detect_claude_home()
    if not claude_home:
        print("ERROR: Cannot locate CLAUDE_HOME", file=sys.stderr)
        sys.exit(1)
    
    state_file = claude_home / '.claude' / 'logs' / 'limit-tracker-state.json'
    
    # Handle log command
    if args.command == 'log':
        if not args.product:
            print("ERROR: Product required for log command", file=sys.stderr)
            print("Usage: claude-stats log <chat|code|cowork> [count]", file=sys.stderr)
            sys.exit(1)
        
        success = log_manual_event(state_file, args.product, args.count)
        sys.exit(0 if success else 1)
    
    # Watch mode - continuous updates
    if args.watch:
        interval = args.watch
        try:
            while True:
                clear_screen()
                state = load_state(state_file)
                status = calculate_status(state)
                print_status(status, show_timestamp=True)
                time.sleep(interval)
        except KeyboardInterrupt:
            clear_screen()
            print("\nWatch mode stopped")
            sys.exit(0)
    
    # One-time commands
    state = load_state(state_file)
    status = calculate_status(state)
    
    if args.command == 'json':
        print(json.dumps(status, indent=2))
    elif args.command == 'reset':
        if status and status['next_reset']:
            reset = status['time_to_reset']
            print(f"Next reset in: {reset['hours']}h {reset['minutes']}m")
        else:
            print("No reset time available")
    else:
        print_status(status)


if __name__ == '__main__':
    main()
